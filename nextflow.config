conda.enabled = true
conda.useMamba = true
outputDir = 'results'
workDir = 'scratch'
resume = true

params {
	outdir = "${outputDir}"
	inputdir = "${launchDir}/input"
	sampleid = "${params.sampleid}"
	KRAKEN2DB = "${launchDir}/databases/k2_standard_16_GB_20250714" // path to kraken2 database
	CHECKMDB = "${launchDir}/databases/CheckM2_database/uniref100.KO.1.dmnd"
	hosts = "${launchDir}/hosts/homo_bos_taurus_gallus_gallus.fna.gz"
	quality = 8
	length = 1000
	bin_size = 100000
	bamsdir = "${params.outdir}/bams"
	mags_catalogue = "${params.outdir}/mags/mags_catalogue.fna"
	magsdir = "${params.outdir}/mags/**/*.assembly.fasta"
	bracken = "${params.outdir}/abundance_correction/bracken/**/*.bracken"
	host_dep_reads = "${params.outdir}/kraken/host_depleted/${params.sampleid}_cleaned.fastq.gz" // 'Input reads file (fastq)'
	threads  =  15
}

process {
		// default environment
		conda = '/home/james/miniconda3/envs/bacteria_meta'

		withName: assemble_mags {
			conda = '/home/james/miniconda3/envs/meta_assembler'
		}
		withName: bin_qc {
			conda = '/home/james/miniconda3/envs/checkm2'
		}

}